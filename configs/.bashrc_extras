# pyinfo — Python environment summary
pyinfo() {
    echo "──────────────────────────────"
    echo " Python env info"
    echo "──────────────────────────────"
    echo " Python:  $(python3 --version 2>/dev/null || echo 'not found')"
    echo " uv:      $(uv --version 2>/dev/null || echo 'not found')"
    echo " which:   $(which python3 2>/dev/null || echo 'not found')"
    echo " venv:    ${VIRTUAL_ENV:-none}"
    echo " conda:   ${CONDA_DEFAULT_ENV:-none}"
    echo " project: $(python3 -c 'import tomllib; d=tomllib.load(open("pyproject.toml","rb")); print(d["project"]["name"])' 2>/dev/null || echo 'none')"
