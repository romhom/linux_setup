    echo "──────────────────────────────"
}

# up — update everything in one command
up() {
    echo "── apt ──────────────────────"
    sudo apt update && sudo apt full-upgrade -y && sudo apt autoremove -y
    echo "── uv tools ─────────────────"
    uv tool upgrade --all
    echo "── pre-commit ───────────────"
    pre-commit autoupdate 2>/dev/null || true
    echo "── setup scripts ────────────"
    bash ~/linux_setup/update.sh
    echo "── done ─────────────────────"
}

