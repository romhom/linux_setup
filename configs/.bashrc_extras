# mk — make dir and cd into it
mk() { mkdir -p "$1" && cd "$1"; }

# extract — handles most archive types
extract() {
    if [[ -f "$1" ]]; then
        case "$1" in
            *.tar.bz2)  tar xjf "$1"        ;;
            *.tar.gz)   tar xzf "$1"        ;;
            *.tar.xz)   tar xJf "$1"        ;;
            *.tar.zst)  tar --zstd -xf "$1" ;;
            *.bz2)      bunzip2 "$1"        ;;
            *.gz)       gunzip "$1"         ;;
            *.tar)      tar xf "$1"         ;;
            *.tbz2)     tar xjf "$1"        ;;
            *.tgz)      tar xzf "$1"        ;;
            *.zip)      unzip "$1"          ;;
            *.Z)        uncompress "$1"     ;;
            *.7z)       7z x "$1"           ;;
            *)          echo "'$1' cannot be extracted" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# mkpy — scaffold a complete uv Python project
mkpy() {
    local name="${1:?Usage: mkpy <project-name>}"
    mkdir -p "$name" && cd "$name"

    uv init --python 3.12
    uv add --dev pytest pytest-cov ruff mypy pre-commit

    # direnv auto-activation
    echo 'source .venv/bin/activate' > .envrc
    command -v direnv &>/dev/null && direnv allow .

    cat > .gitignore <<'GITIGNORE'
.venv/
.env
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/
dist/
build/
*.egg-info/
.DS_Store
GITIGNORE

    cat >> pyproject.toml <<'TOML'

[tool.ruff]
line-length = 88
target-version = "py312"

[tool.ruff.lint]
select = ["E", "F", "I", "N", "W", "UP"]

[tool.ruff.format]
quote-style = "double"

[tool.mypy]
python_version = "3.12"
strict = false
ignore_missing_imports = true

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "--cov=src --cov-report=term-missing"
TOML

    cat > .pre-commit-config.yaml <<'YAML'
repos:
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.4.0
    hooks:
      - id: ruff
        args: [--fix]
      - id: ruff-format
  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v4.6.0
    hooks:
      - id: trailing-whitespace
      - id: end-of-file-fixer
      - id: check-yaml
      - id: check-toml
      - id: debug-statements
YAML

    cat > Makefile <<'MAKEFILE'
.PHONY: install test lint format typecheck secure clean

install:
	uv sync

test:
	uv run pytest

lint:
	uv run ruff check .

format:
	uv run ruff format .

typecheck:
	uv run mypy src/

secure:
	uv run bandit -r src/

clean:
	find . -type d -name __pycache__ -exec rm -rf {} +
	find . -name "*.pyc" -delete
	rm -rf .pytest_cache .ruff_cache .mypy_cache dist build
MAKEFILE

    mkdir -p tests && touch tests/__init__.py
    uv run pre-commit install
    git init && git add . && git commit -m "initial commit"

    echo ""
    echo "Project '$name' ready."
    echo "  make install   — sync deps"
    echo "  make test      — run tests"
    echo "  make lint      — lint"
    echo "  make format    — format"
    echo "  make secure    — security scan"
    echo ""
}

