# ── Starship prompt switching ─────────────────────────────────────────────────
# prompt-nerd  — switch to full Nerd Font prompt (requires Nerd Font in terminal)
# prompt-simple — switch to plain prompt (works with any font)
prompt-nerd() {
    ln -sf "$HOME/.config/starship/nerd.toml" "$HOME/.config/starship.toml"
    echo "Switched to Nerd Font prompt — restart terminal or run: reload"
}
prompt-simple() {
    ln -sf "$HOME/.config/starship/simple.toml" "$HOME/.config/starship.toml"
    echo "Switched to simple prompt — restart terminal or run: reload"
}
prompt-status() {
    local cfg
    cfg=$(readlink "$HOME/.config/starship.toml" 2>/dev/null || echo "unknown")
    echo "Active prompt: $(basename "$cfg" .toml)"
}

