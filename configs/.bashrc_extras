# ── bashrc dedup — run once if terminal feels slow ────────────────────────────
bashrc-dedup() {
    local backup="$HOME/.bashrc.bak.$(date +%Y%m%d%H%M%S)"
    cp "$HOME/.bashrc" "$backup"
    echo "Backup saved: $backup"

    # Remove duplicate lines while preserving order and blank lines
    awk '
        /^[[:space:]]*$/ { print; next }
        !seen[$0]++ { print }
    ' "$HOME/.bashrc" > /tmp/.bashrc_deduped

    # Count how many lines removed
    local before after
    before=$(wc -l < "$HOME/.bashrc")
    after=$(wc -l < /tmp/.bashrc_deduped)
    mv /tmp/.bashrc_deduped "$HOME/.bashrc"
    echo "Removed $((before - after)) duplicate lines from .bashrc"
    echo "Run: source ~/.bashrc"
}
