# ── SSH agent persistence ─────────────────────────────────────────────────────
# Keeps agent alive across terminal sessions — only prompts for passphrase once
SSH_ENV="$HOME/.ssh/agent-env"
_start_ssh_agent() {
    mkdir -p "$HOME/.ssh"
    ssh-agent | sed 's/^echo/#echo/' > "$SSH_ENV"
    chmod 600 "$SSH_ENV"
    source "$SSH_ENV" > /dev/null
    ssh-add "$HOME/.ssh/id_ed25519" 2>/dev/null || true
}
if [[ -f "$SSH_ENV" ]]; then
    source "$SSH_ENV" > /dev/null 2>&1
    kill -0 "$SSH_AGENT_PID" 2>/dev/null || _start_ssh_agent
else
    _start_ssh_agent
fi

